{
  "name": "AlRayyan",
  "description": "نظام إدارة سوبر ماركت وصيدلية متكامل مع دعم العملات المزدوجة",
  "author": {
    "name": "Bader_Alraslan",
    "email": "raslanbader@gmail.com"
  },
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron dist-server",
    "lint": "tsc --noEmit",
    "build:server": "tsc server.ts --outDir dist-server --module ESNext --target ES2022 --moduleResolution bundler --allowJs --skipLibCheck --esModuleInterop",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3131 && electron .\"",
    "electron:build": "npm run build && npm run build:server && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.AlRayyan.supermarket",
    "productName": "AlRayyan Supermarket System",
    "icon": "build/icon.ico",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "electron-main.cjs",
      "package.json",
      "preload.cjs"
    ],
    "extraResources": [
      "supermarket.db"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@types/cors": "^2.8.19",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "react-to-print": "^3.3.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
