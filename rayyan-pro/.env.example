# ========================================
# Rayyan Pro — Environment Variables
# Copy this file to .env and fill in values
# ========================================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/rayyan_pro
PGHOST=localhost
PGPORT=5432
PGUSER=user
PGPASSWORD=password
PGDATABASE=rayyan_pro

# --- Server ---
PORT=3200
NODE_ENV=development

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_this_to_a_long_random_secret_access
JWT_REFRESH_SECRET=change_this_to_a_long_random_secret_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- App ---
APP_NAME=Rayyan Pro
DEFAULT_CURRENCY=USD
DEFAULT_LANGUAGE=ar
