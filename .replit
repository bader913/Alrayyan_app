modules = ["nodejs-20", "web", "python-3.11"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rayyan Pro"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Alrayyan_app && npx concurrently \"npx tsx server.ts\" \"npx vite --port 5000 --host 0.0.0.0\""
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Rayyan Pro"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd rayyan-pro && npm run dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "work1"
mode = "sequential"
author = 5642290

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rayyan Pro"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3131
externalPort = 3001

[[ports]]
localPort = 3200
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3003

[[ports]]
localPort = 5002
externalPort = 4200

[[ports]]
localPort = 24678
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "NODE_ENV=production node rayyan-pro/server/dist/index.js"]
build = ["bash", "-c", "cd rayyan-pro && npm install && cd server && npm install && cd ../client && npm install && cd .. && npm run build && npm run migrate"]
